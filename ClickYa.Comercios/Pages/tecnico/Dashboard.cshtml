@page "/Tecnico/Dashboard"
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>Dashboard Técnico – ClickYa</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="stylesheet" href="~/css/site.css" />
    <style>
        .msg-ok {
            font-size: 13px;
            color: #16A34A;
            text-align: center;
            display: none;
            margin-top: 8px;
        }

        .badge-premium {
            display: inline-block;
            background: #EDE9FE;
            color: #5B21B6;
            font-size: 11px;
            font-weight: 700;
            padding: 3px 10px;
            border-radius: 999px;
            margin-left: 8px;
        }

        .publicaciones-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(220px,1fr));
            gap: 16px;
            margin-top: 16px;
        }

        .pub-card {
            background: #fff;
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 8px 20px rgba(0,0,0,.08);
            position: relative;
        }

            .pub-card img {
                width: 100%;
                height: 160px;
                object-fit: cover;
            }

            .pub-card .pub-info {
                padding: 12px;
            }

                .pub-card .pub-info h3 {
                    font-size: 14px;
                    color: #111;
                    margin: 0 0 4px;
                }

                .pub-card .pub-info p {
                    font-size: 12px;
                    color: #666;
                    margin: 0;
                }

        .btn-edit-pub {
            position: absolute;
            top: 10px;
            right: 10px;
            background: rgba(0,0,0,.7);
            color: #fff;
            border: none;
            padding: 6px 10px;
            border-radius: 10px;
            cursor: pointer;
            font-size: 12px;
        }

        .modal-pub {
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,.55);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 9999;
        }

        .modal-content {
            background: #fff;
            border-radius: 20px;
            padding: 24px;
            width: 520px;
            max-width: 92%;
            max-height: 84vh;
            overflow: auto;
        }

            .modal-content h3 {
                margin-bottom: 16px;
                color: #4B0082;
            }

            .modal-content label {
                font-size: 13px;
                margin-top: 12px;
                display: block;
            }

            .modal-content input, .modal-content textarea {
                width: 100%;
                padding: 10px;
                border-radius: 12px;
                border: 1px solid #ddd;
                margin-top: 6px;
                font-size: 14px;
            }

            .modal-content textarea {
                min-height: 100px;
                resize: vertical;
            }

        .modal-actions {
            margin-top: 18px;
            display: flex;
            justify-content: flex-end;
            gap: 12px;
        }

        .btn-danger {
            background: #dc2626;
            color: white;
            border: none;
            padding: 8px 14px;
            border-radius: 10px;
            cursor: pointer;
        }

        .modal-img {
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,.85);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 99999;
        }

            .modal-img img {
                max-width: 90%;
                max-height: 90%;
                border-radius: 16px;
            }

        .modal-close {
            position: absolute;
            top: 20px;
            right: 24px;
            font-size: 32px;
            color: white;
            cursor: pointer;
        }

        .field {
            margin-bottom: 12px;
        }

            .field label {
                font-size: 13px;
                font-weight: 600;
                color: #555;
                display: block;
                margin-bottom: 4px;
            }

            .field input, .field textarea {
                width: 100%;
                padding: 10px 14px;
                border-radius: 10px;
                border: 1px solid #ddd;
                font-size: 14px;
            }

            .field textarea {
                resize: none;
            }

        .section-title {
            font-size: 20px;
            font-weight: 700;
            color: #111;
            margin-bottom: 16px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .btn-agregar-pub {
            background: #4B0082;
            color: white;
            border: none;
            padding: 8px 16px;
            border-radius: 10px;
            font-weight: 700;
            font-size: 13px;
            cursor: pointer;
        }
    </style>
</head>
<body class="cy-body">

    <div class="cy-topbar">
        <button class="cy-menu-btn" onclick="document.getElementById('cySidebar').classList.add('open')">☰</button>
    </div>

    <div id="cyOverlay" class="cy-overlay" onclick="cerrarSidebar()"></div>

    <div class="cy-shell">

        <aside id="cySidebar" class="cy-sidebar">
            <div class="cy-brand" style="justify-content:center">
                <img src="/images/logo_clickya.png" class="cy-logo" />
            </div>
            <nav class="cy-nav">
                <a class="cy-navlink" href="#" onclick="document.getElementById('modalPerfil').style.display='flex'; return false;">Editar perfil</a>
                <hr class="cy-sep" />
                <a class="cy-navlink" href="/">Salir</a>
            </nav>
        </aside>

        <main class="cy-content">
            <div class="local-preview">

                <div class="local-portada">
                    <img id="imgPortada" src="/images/1.jfif" />
                    <button class="btn-edit" onclick="document.getElementById('inputPortada').click()">📷 Cambiar portada</button>
                    <input type="file" id="inputPortada" accept="image/*" hidden />
                </div>

                <div class="local-info">
                    <div class="local-logo">
                        <img id="imgLogo" src="/images/logo_clickya.png" onclick="document.getElementById('inputLogo').click()" style="cursor:pointer" title="Click para cambiar logo" />
                        <input type="file" id="inputLogo" accept="image/*" hidden />
                    </div>
                    <div class="local-data">
                        <h1 id="txtNombre" style="font-size:22px;margin:0;">Cargando...</h1>
                        <div class="local-meta" id="txtRubro"></div>
                        <div class="local-desc" id="txtDesc"></div>
                        <span id="badgePremium" class="badge-premium" style="display:none">⭐ Premium</span>
                        <div id="txtLinks" style="display:flex;gap:12px;flex-wrap:wrap;margin-top:8px;font-size:13px;"></div>
                    </div>
                </div>

                <div class="local-section">
                    <div class="section-title">
                        Publicaciones
                        <button class="btn-agregar-pub" onclick="abrirModalAgregar()">+ Agregar</button>
                    </div>
                    <div class="publicaciones-grid" id="gridPublicaciones"></div>
                </div>

            </div>
        </main>
    </div>

    <!-- MODAL PERFIL -->
    <div id="modalPerfil" class="cy-modal" style="display:none">
        <div class="cy-modal-box">
            <div class="cy-modal-body">
                <h2>Editar perfil</h2>
                <div class="field">
                    <label>Nombre</label>
                    <input id="inpNombre" type="text" class="form-control" />
                </div>
                <div class="field">
                    <label>Dirección</label>
                    <input id="inpDireccion" type="text" class="form-control" />
                </div>
                <div class="field">
                    <label>Descripción</label>
                    <textarea id="inpDescripcion" rows="3" class="form-control"></textarea>
                </div>
                <div class="field">
                    <label>WhatsApp</label>
                    <input id="inpWhatsApp" type="text" class="form-control" />
                </div>
                <div class="field">
                    <label>Instagram (opcional)</label>
                    <input id="inpInstagram" type="text" class="form-control" placeholder="@@usuario" />
                </div>
                <div class="field">
                    <label>Ubicación (link Google Maps)</label>
                    <input id="inpUbicacion" type="text" class="form-control" placeholder="https://maps.google.com/..." />
                </div>
                <div style="display:flex;justify-content:flex-end;gap:10px;margin-top:14px">
                    <button class="btn btn-secondary" onclick="document.getElementById('modalPerfil').style.display='none'">Cerrar</button>
                    <button class="btn btn-dark" onclick="guardarPerfil()">Guardar</button>
                </div>
                <p class="msg-ok" id="msgPerfil">✅ Perfil guardado</p>
            </div>
        </div>
    </div>

    <!-- MODAL AGREGAR -->
    <div class="modal-pub" id="modalAgregar">
        <div class="modal-content">
            <h3>Agregar publicación</h3>
            <label>Imágenes</label>
            <input type="file" id="addImagenes" accept="image/*" multiple />
            <label>Título</label>
            <input type="text" id="addTitulo" />
            <label>Descripción</label>
            <textarea id="addDescripcion"></textarea>
            <div class="modal-actions">
                <button class="btn-secondary" onclick="cerrarModalAgregar()">Cancelar</button>
                <button class="btn-dark" onclick="guardarPublicacion()">Guardar</button>
            </div>
        </div>
    </div>

    <!-- MODAL EDITAR -->
    <div class="modal-pub" id="modalEditar">
        <div class="modal-content">
            <h3>Editar publicación</h3>
            <label>Imágenes actuales</label>
            <div id="imagenesActuales" style="display:flex;flex-wrap:wrap;gap:4px;margin-top:6px;"></div>
            <label>Reemplazar imágenes (opcional)</label>
            <input type="file" id="editImagenes" accept="image/*" multiple />
            <label>Título</label>
            <input type="text" id="editTitulo" />
            <label>Descripción</label>
            <textarea id="editDescripcion"></textarea>
            <div class="modal-actions">
                <button class="btn-danger" onclick="eliminarPublicacion()">Eliminar</button>
                <button class="btn-secondary" onclick="cerrarModalEditar()">Cancelar</button>
                <button class="btn-dark" onclick="guardarEdicion()">Guardar</button>
            </div>
        </div>
    </div>

    <!-- MODAL IMAGEN GRANDE -->
    <div class="modal-img" id="modalImg">
        <span class="modal-close" onclick="cerrarModalImg()">&times;</span>
        <span onclick="galeriaAnterior()" style="position:absolute;left:20px;font-size:48px;color:white;cursor:pointer;user-select:none;">&#10094;</span>
        <img id="modalImgSrc" src="" />
        <span onclick="galeriaSiguiente()" style="position:absolute;right:20px;font-size:48px;color:white;cursor:pointer;user-select:none;">&#10095;</span>
    </div>

    <script>
        const API = 'https://clickya-production.up.railway.app';
        const params = new URLSearchParams(window.location.search);
        const token = params.get('token');
        let tecnico = null;
        let pubEditandoId = null;

        async function init() {
            if (!token) return;
            try {
                const r = await fetch(`${API}/api/Tecnico/token/${token}`);
                if (!r.ok) throw new Error();
                tecnico = await r.json();

                document.getElementById('txtNombre').textContent = tecnico.nombre || '';
                document.getElementById('txtRubro').textContent = tecnico.rubro || '';
                document.getElementById('txtDesc').textContent = tecnico.descripcion || '';

                const links = [];
                if (tecnico.whatsApp) links.push(`<a href="https://wa.me/54${tecnico.whatsApp}" target="_blank" style="color:#25D366;font-weight:600;">📲 WhatsApp</a>`);
                if (tecnico.instagram) links.push(`<a href="https://instagram.com/${tecnico.instagram}" target="_blank" style="color:#E1306C;font-weight:600;">📸 Instagram</a>`);
                if (tecnico.direccion) links.push(`<span style="color:#666;">📍 ${tecnico.direccion}</span>`);
                if (tecnico.ubicacion) links.push(`<a href="${tecnico.ubicacion}" target="_blank" style="color:#4B0082;font-weight:600;">🗺️ Ver ubicación</a>`);
                document.getElementById('txtLinks').innerHTML = links.join('');

                if (tecnico.esPremium) document.getElementById('badgePremium').style.display = 'inline-block';
                if (tecnico.fotoPortada) document.getElementById('imgPortada').src = API + tecnico.fotoPortada;
                if (tecnico.logo) document.getElementById('imgLogo').src = API + tecnico.logo;

                document.getElementById('inpNombre').value = tecnico.nombre || '';
                document.getElementById('inpDireccion').value = tecnico.direccion || '';
                document.getElementById('inpDescripcion').value = tecnico.descripcion || '';
                document.getElementById('inpWhatsApp').value = tecnico.whatsApp || '';
                document.getElementById('inpInstagram').value = tecnico.instagram || '';
                document.getElementById('inpUbicacion').value = tecnico.ubicacion || '';

                cargarPublicaciones();

                try {
                    const rMsg = await fetch(`${API}/api/MensajeAdmin/tecnico/${tecnico.id}`);
                    const mensajes = await rMsg.json();
                    if (mensajes.length > 0) {
                        const banner = document.createElement('div');
                        banner.style.cssText = 'background:#EDE9FE;border-left:4px solid #7C3AED;padding:14px 18px;border-radius:12px;margin-bottom:16px;font-size:14px;color:#4B0082;';
                        banner.innerHTML = mensajes.map(m => `📢 ${m.texto}`).join('<br>');
                        document.querySelector('.local-preview').prepend(banner);
                    }
                } catch(e) {}

                document.getElementById('inputPortada').addEventListener('change', async function () {
                    const file = this.files[0];
                    if (!file) return;
                    const formData = new FormData();
                    formData.append('archivo', file);
                    const res = await fetch(`${API}/api/Tecnico/${tecnico.id}/portada`, { method: 'POST', body: formData });
                    if (res.ok) {
                        const data = await res.json();
                        document.getElementById('imgPortada').src = API + data.portadaUrl + '?t=' + Date.now();
                    }
                });

                document.getElementById('inputLogo').addEventListener('change', async function () {
                    const file = this.files[0];
                    if (!file) return;
                    const formData = new FormData();
                    formData.append('archivo', file);
                    const res = await fetch(`${API}/api/Tecnico/${tecnico.id}/logo`, { method: 'POST', body: formData });
                    if (res.ok) {
                        const data = await res.json();
                        document.getElementById('imgLogo').src = API + data.logoUrl + '?t=' + Date.now();
                    }
                });

            } catch (e) { console.error(e); }
        }

        async function guardarPerfil() {
             const direccion = document.getElementById('inpDireccion').value.trim();

             let latitud = tecnico.latitud || 0;
             let longitud = tecnico.longitud || 0;

             if (direccion && !direccion.startsWith('http')) {
                 try {
                     const geo = await fetch(
                         `https://nominatim.openstreetmap.org/search?q=${encodeURIComponent(direccion + ', San Nicolas, Buenos Aires')}&format=json&limit=1`
                     );
                     const geoData = await geo.json();
                     if (geoData.length > 0) {
                         latitud = parseFloat(geoData[0].lat);
                         longitud = parseFloat(geoData[0].lon);
                     }
                 } catch(e) {}
             }

             const datos = {
                 ...tecnico,
                 nombre: document.getElementById('inpNombre').value.trim(),
                 direccion: direccion,
                 descripcion: document.getElementById('inpDescripcion').value.trim(),
                 whatsApp: document.getElementById('inpWhatsApp').value.trim(),
                 instagram: document.getElementById('inpInstagram').value.trim(),
                 ubicacion: document.getElementById('inpUbicacion').value.trim(),
                 latitud: latitud,
                 longitud: longitud
             };
             await fetch(`${API}/api/Tecnico/${tecnico.id}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(datos)
            });
            tecnico = datos;
            document.getElementById('txtNombre').textContent = datos.nombre;
            document.getElementById('txtDesc').textContent = datos.descripcion;
            document.getElementById('modalPerfil').style.display = 'none';
            const msg = document.getElementById('msgPerfil');
            msg.style.display = 'block';
            setTimeout(() => msg.style.display = 'none', 3000);
        }

        async function cargarPublicaciones() {
            const r = await fetch(`${API}/api/Publicacion/tecnico/${tecnico.id}`);
            const lista = await r.json();
            const grid = document.getElementById('gridPublicaciones');
            grid.innerHTML = '';
            lista.forEach(pub => agregarCard(pub));
        }

        function agregarCard(pub) {
            const grid = document.getElementById('gridPublicaciones');
            const card = document.createElement('div');
            card.className = 'pub-card';
            card.dataset.id = pub.id;
            const img = pub.imagenes && pub.imagenes.length > 0 ? API + pub.imagenes[0] : '/images/1.jfif';
            const cantImg = pub.imagenes ? pub.imagenes.length : 0;
            card.innerHTML = `
                <div style="position:relative;cursor:pointer;">
                    <img id="cardImg_${pub.id}" src="${img}" style="width:100%;height:160px;object-fit:cover;" />
                    <div style="position:absolute;top:10px;left:10px;background:rgba(0,0,0,.6);color:white;font-size:11px;padding:3px 8px;border-radius:8px;">
                        📷 ${cantImg} foto${cantImg !== 1 ? 's' : ''}
                    </div>
                </div>
                <div class="pub-info">
                    <h3>${escHtml(pub.titulo)}</h3>
                    <p id="desc_${pub.id}" style="overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;">${escHtml(pub.descripcion)}</p>
                    <span onclick="toggleDesc('desc_${pub.id}', this)" style="font-size:11px;color:#7C3AED;cursor:pointer;font-weight:600;">Ver más</span>
                </div>
            `;

            const imgEl = card.querySelector(`#cardImg_${pub.id}`);
            imgEl.addEventListener('click', () => abrirGaleria(pub.imagenes, 0));

            const btnEditar = document.createElement('button');
            btnEditar.className = 'btn-edit-pub';
            btnEditar.textContent = 'Editar';
            btnEditar.addEventListener('click', () => abrirModalEditar(pub.id, pub));
            card.appendChild(btnEditar);
            grid.prepend(card);
        }

        function abrirModalAgregar() {
            document.getElementById('addTitulo').value = '';
            document.getElementById('addDescripcion').value = '';
            document.getElementById('addImagenes').value = '';
            document.getElementById('modalAgregar').style.display = 'flex';
        }

        function cerrarModalAgregar() { document.getElementById('modalAgregar').style.display = 'none'; }

        function abrirModalEditar(id, pub) {
            pubEditandoId = id;
            document.getElementById('editTitulo').value = pub.titulo || '';
            document.getElementById('editDescripcion').value = pub.descripcion || '';
            document.getElementById('editImagenes').value = '';

            const contenedor = document.getElementById('imagenesActuales');
            contenedor.innerHTML = '';

            if (pub.imagenes && pub.imagenes.length > 0) {
                pub.imagenes.forEach((img, i) => {
                    const div = document.createElement('div');
                    div.style.cssText = 'position:relative;display:inline-block;';

                    const imgEl = document.createElement('img');
                    imgEl.src = API + img;
                    imgEl.style.cssText = 'width:80px;height:80px;object-fit:cover;border-radius:8px;margin:4px;cursor:pointer;';
                    imgEl.addEventListener('click', () => {
                        document.getElementById('modalImgSrc').src = API + img;
                        document.getElementById('modalImg').style.display = 'flex';
                    });

                    const span = document.createElement('span');
                    span.style.cssText = 'position:absolute;top:2px;right:2px;background:rgba(0,0,0,.6);color:white;font-size:10px;padding:2px 5px;border-radius:6px;';
                    span.textContent = i + 1;

                    div.appendChild(imgEl);
                    div.appendChild(span);
                    contenedor.appendChild(div);
                });
            } else {
                contenedor.innerHTML = '<p style="font-size:12px;color:#999;">Sin imágenes</p>';
            }

            document.getElementById('modalEditar').style.display = 'flex';
        }

        function cerrarModalEditar() { document.getElementById('modalEditar').style.display = 'none'; }

        async function guardarEdicion() {
            const titulo = document.getElementById('editTitulo').value.trim();
            const descripcion = document.getElementById('editDescripcion').value.trim();
            const imagenes = document.getElementById('editImagenes').files;
            const maxImg = tecnico.esPremium ? 20 : 8;
            const formData = new FormData();
            formData.append('Titulo', titulo);
            formData.append('Descripcion', descripcion);
            Array.from(imagenes).slice(0, maxImg).forEach(f => formData.append('Imagenes', f));
            const res = await fetch(`${API}/api/Publicacion/${pubEditandoId}?token=${token}`, { method: 'PUT', body: formData });
            if (res.ok) { await cargarPublicaciones(); cerrarModalEditar(); }
            else alert('Error al editar');
        }

        async function guardarPublicacion() {
            const titulo = document.getElementById('addTitulo').value.trim();
            const descripcion = document.getElementById('addDescripcion').value.trim();
            const imagenes = document.getElementById('addImagenes').files;
            if (!titulo) { alert('El título es obligatorio'); return; }

            const maxImg = tecnico.esPremium ? 20 : 8;

            if (!tecnico.esPremium && imagenes.length > 8) {
                const pasar = confirm('⭐ Límite del plan gratuito: 8 imágenes por publicación.\n¿Querés pasarte a Premium para subir hasta 20 imágenes?');
                if (pasar) alert('Contactá al administrador de ClickYa para activar tu plan Premium.');
                return;
            }

            const formData = new FormData();
            formData.append('Titulo', titulo);
            formData.append('Descripcion', descripcion);
            Array.from(imagenes).slice(0, maxImg).forEach(f => formData.append('Imagenes', f));
            const res = await fetch(`${API}/api/Publicacion?token=${token}`, { method: 'POST', body: formData });
            if (res.ok) { const nueva = await res.json(); agregarCard(nueva); cerrarModalAgregar(); }
            else alert('Error al guardar');
        }

        async function eliminarPublicacion() {
            if (!confirm('¿Eliminar esta publicación?')) return;
            const res = await fetch(`${API}/api/Publicacion/${pubEditandoId}?token=${token}`, { method: 'DELETE' });
            if (res.ok) { await cargarPublicaciones(); cerrarModalEditar(); }
        }

        function cerrarModalImg() { document.getElementById('modalImg').style.display = 'none'; }

        function cerrarSidebar() {
            document.getElementById('cySidebar').classList.remove('open');
            document.getElementById('cyOverlay').classList.remove('show');
        }

        function escHtml(str) {
            return (str ?? '').toString()
                .replaceAll('&', '&amp;').replaceAll('<', '&lt;')
                .replaceAll('>', '&gt;').replaceAll('"', '&quot;')
                .replaceAll("'", '&#039;');
        }

        let galeriaImagenes = [];
        let galeriaIndex = 0;

        function abrirGaleria(imagenes, index) {
            galeriaImagenes = imagenes && imagenes.length > 0 ? imagenes : [];
            galeriaIndex = index;
            if (galeriaImagenes.length === 0) return;
            document.getElementById('modalImgSrc').src = API + galeriaImagenes[galeriaIndex];
            document.getElementById('modalImg').style.display = 'flex';
        }

        function galeriaAnterior() {
            if (galeriaImagenes.length === 0) return;
            galeriaIndex = (galeriaIndex - 1 + galeriaImagenes.length) % galeriaImagenes.length;
            document.getElementById('modalImgSrc').src = API + galeriaImagenes[galeriaIndex];
        }

        function galeriaSiguiente() {
            if (galeriaImagenes.length === 0) return;
            galeriaIndex = (galeriaIndex + 1) % galeriaImagenes.length;
            document.getElementById('modalImgSrc').src = API + galeriaImagenes[galeriaIndex];
        }

        function toggleDesc(id, btn) {
            const p = document.getElementById(id);
            if (p.style.webkitLineClamp === '2' || p.style.webkitLineClamp === '') {
                p.style.webkitLineClamp = 'unset';
                p.style.webkitBoxOrient = 'unset';
                p.style.display = 'block';
                btn.textContent = 'Ver menos';
            } else {
                p.style.display = '-webkit-box';
                p.style.webkitLineClamp = '2';
                p.style.webkitBoxOrient = 'vertical';
                btn.textContent = 'Ver más';
            }
        }
       

             async function cargarUrgencias() {
            if (!tecnico) return;
            try {
                const r = await fetch(`${API}/api/Urgencia/tecnico/${tecnico.id}`);
                const lista = await r.json();
                if (lista.length === 0) return;
                const section = document.createElement('div');
                section.className = 'local-section';
                section.innerHTML = `
                    <div class="section-title" style="color:#dc2626;">🚨 Urgencias recibidas</div>
                    <div id="listaUrgencias"></div>
                `;
                document.querySelector('.local-preview').insertBefore(section, document.querySelector('.local-section'));
                const contenedor = document.getElementById('listaUrgencias');
                lista.forEach(u => {
                    const fecha = new Date(u.fecha).toLocaleDateString('es-AR', { day:'numeric', month:'short', hour:'2-digit', minute:'2-digit' });
                    contenedor.innerHTML += `
                        <div style="background:#fff;border-radius:16px;padding:16px;margin-bottom:12px;box-shadow:0 4px 12px rgba(0,0,0,.08);border-left:4px solid ${u.estado === 'Nueva' ? '#dc2626' : '#22c55e'}">
                            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;">
                                <span style="font-weight:700;font-size:15px;">${escHtml(u.rubro)}</span>
                                <span style="font-size:12px;padding:3px 10px;border-radius:999px;background:${u.estado === 'Nueva' ? '#fee2e2' : '#dcfce7'};color:${u.estado === 'Nueva' ? '#dc2626' : '#16a34a'};font-weight:700;">${u.estado}</span>
                            </div>
                            <p style="font-size:14px;color:#444;margin:0 0 8px;">${escHtml(u.descripcion)}</p>
                            ${u.fotoUrl ? `<img src="${u.fotoUrl}" style="width:100%;max-height:180px;object-fit:cover;border-radius:12px;margin-bottom:8px;">` : ''}
                            <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap;">
                                <a href="https://wa.me/${u.whatsAppCliente}" target="_blank" style="background:#25D366;color:white;padding:7px 14px;border-radius:10px;font-size:13px;font-weight:700;text-decoration:none;">📲 Contactar</a>
                                <span style="font-size:12px;color:#888;">${fecha}</span>
                            </div>
                        </div>
                    `;
                });
            } catch(e) { console.error(e); }
        }
        init().then(() => cargarUrgencias());
    </script>

</body>
</html>