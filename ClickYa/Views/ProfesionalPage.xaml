<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="ClickYa.Views.ProfesionalPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Profesional"
    Shell.NavBarIsVisible="True">

    <!-- FONDO DEGRADADO (IGUAL A SERVICIOS) -->
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#4B0082" Offset="0"/>
                <GradientStop Color="#B8008A" Offset="0.6"/>
                <GradientStop Color="#FF3D3D" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- CONTENIDO ORIGINAL -->
        <Grid Padding="10">

            <Frame
                CornerRadius="26"
                BorderColor="#E6008A"
                BackgroundColor="White"
                HasShadow="False"
                Padding="0">

                <ScrollView>

                    <VerticalStackLayout Spacing="0">

                        <!-- PORTADA -->
                        <Grid HeightRequest="200">
                            <Image Source="banner1.png" Aspect="AspectFill"/>

                            <Frame
                                WidthRequest="90"
                                HeightRequest="90"
                                CornerRadius="45"
                                BackgroundColor="White"
                                BorderColor="#E6008A"
                                Padding="4"
                                VerticalOptions="End"
                                HorizontalOptions="Center"
                                Margin="0,0,0,-45">

                                <Image Source="logo_clickya.png"
       Aspect="AspectFill">
                                    <Image.GestureRecognizers>
                                        <TapGestureRecognizer
            Tapped="OnImageTapped"
            CommandParameter="logo|0"/>
                                    </Image.GestureRecognizers>
                                </Image>

                            </Frame>
                        </Grid>

                        <!-- INFO -->
                        <VerticalStackLayout Padding="20,55,20,6" HorizontalOptions="Center">
                            <Label Text="Moda" FontSize="20" FontAttributes="Bold" TextColor="#222"/>
                            <Label Text="San Nicolás" FontSize="13" TextColor="#777"/>
                        </VerticalStackLayout>

                        <!-- DESCRIPCIÓN -->
                        <Frame
                            Margin="20,8,20,14"
                            Padding="18,16"
                            CornerRadius="18"
                            BackgroundColor="#FAFAFA"
                            BorderColor="#E6008A"
                            HasShadow="False">

                            <Label
                                Text="👕 Moda urbana y personalizada&#10;
✂️ Diseños exclusivos y a medida&#10;
🚚 Envíos en San Nicolás&#10;
⭐ Atención directa con el cliente"
                                FontSize="15"
                                LineHeight="1.35"
                                TextColor="#333"/>
                        </Frame>

                        <!-- BOTONES -->
                        <HorizontalStackLayout
                            Spacing="10"
                            HorizontalOptions="Center"
                            Margin="0,10,0,20">

                            <Button
                                Text="WhatsApp"
                                BackgroundColor="#25D366"
                                TextColor="White"
                                CornerRadius="18"
                                Padding="22,10"
                                FontSize="14"
                                Clicked="OnWhatsAppClicked"/>

                            <Button
                                Text="Instagram"
                                BackgroundColor="#E6008A"
                                TextColor="White"
                                CornerRadius="18"
                                Padding="22,10"
                                FontSize="14"
                                Clicked="OnInstagramClicked"/>

                            <Button
                                Text="Ubicación"
                                BackgroundColor="#E0E0E0"
                                TextColor="#333"
                                CornerRadius="18"
                                Padding="22,10"
                                FontSize="14"
                                Clicked="OnUbicacionClicked"/>

                        </HorizontalStackLayout>

                        <!-- PUBLICACIONES -->
                        <Label Text="Publicaciones"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="#222"
                               Margin="20,0,0,10"/>

                        <!-- ===== PUBLICACIÓN 1 ===== -->
                        <VerticalStackLayout Padding="16" Spacing="10">

                            <ScrollView Orientation="Horizontal" HeightRequest="230">
                                <HorizontalStackLayout Spacing="12">

                                    <Image Source="banner1.png" WidthRequest="280" HeightRequest="220" Aspect="AspectFill">
                                        <Image.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnImageTapped" CommandParameter="pub1|0"/>
                                        </Image.GestureRecognizers>
                                    </Image>

                                    <Image Source="banner2.png" WidthRequest="280" HeightRequest="220" Aspect="AspectFill">
                                        <Image.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnImageTapped" CommandParameter="pub1|1"/>
                                        </Image.GestureRecognizers>
                                    </Image>

                                    <Image Source="banner3.png" WidthRequest="280" HeightRequest="220" Aspect="AspectFill">
                                        <Image.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnImageTapped" CommandParameter="pub1|2"/>
                                        </Image.GestureRecognizers>
                                    </Image>

                                </HorizontalStackLayout>
                            </ScrollView>

                            <Label Text="Nueva colección urbana. Prendas cómodas y modernas."
                                   FontSize="14" TextColor="#444"/>
                        </VerticalStackLayout>

                        <BoxView HeightRequest="1" BackgroundColor="#F2F2F2"/>

                        <!-- ===== PUBLICACIÓN 2 ===== -->
                        <VerticalStackLayout Padding="16" Spacing="8">

                            <ScrollView Orientation="Horizontal" HeightRequest="230">
                                <HorizontalStackLayout Spacing="10">

                                    <Image Source="paleta_agua_frutilla.png" WidthRequest="260" HeightRequest="220" Aspect="AspectFill">
                                        <Image.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnImageTapped" CommandParameter="pub2|0"/>
                                        </Image.GestureRecognizers>
                                    </Image>

                                    <Image Source="paleta_chocolate.png" WidthRequest="260" HeightRequest="220" Aspect="AspectFill">
                                        <Image.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnImageTapped" CommandParameter="pub2|1"/>
                                        </Image.GestureRecognizers>
                                    </Image>

                                    <Image Source="helado_pote.png" WidthRequest="260" HeightRequest="220" Aspect="AspectFill">
                                        <Image.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnImageTapped" CommandParameter="pub2|2"/>
                                        </Image.GestureRecognizers>
                                    </Image>

                                </HorizontalStackLayout>
                            </ScrollView>

                            <Label Text="Trabajos personalizados y atención directa."
                                   FontSize="14" TextColor="#444"/>
                        </VerticalStackLayout>

                        <BoxView HeightRequest="1" BackgroundColor="#F2F2F2"/>

                        <!-- ===== PUBLICACIÓN 3 ===== -->
                        <VerticalStackLayout Padding="16" Spacing="8">

                            <ScrollView Orientation="Horizontal" HeightRequest="230">
                                <HorizontalStackLayout Spacing="10">

                                    <Image Source="ropadeporte.png" WidthRequest="260" HeightRequest="220" Aspect="AspectFill">
                                        <Image.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnImageTapped" CommandParameter="pub3|0"/>
                                        </Image.GestureRecognizers>
                                    </Image>

                                    <Image Source="tecnico.png" WidthRequest="260" HeightRequest="220" Aspect="AspectFill">
                                        <Image.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnImageTapped" CommandParameter="pub3|1"/>
                                        </Image.GestureRecognizers>
                                    </Image>

                                    <Image Source="automotores.png" WidthRequest="260" HeightRequest="220" Aspect="AspectFill">
                                        <Image.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnImageTapped" CommandParameter="pub3|2"/>
                                        </Image.GestureRecognizers>
                                    </Image>

                                </HorizontalStackLayout>
                            </ScrollView>

                            <Label Text="Producciones recientes y trabajos destacados."
                                   FontSize="14" TextColor="#444"/>
                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </ScrollView>
            </Frame>
        </Grid>
    </Grid>
</ContentPage>
